# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic (Claude API for assessment matching)
ANTHROPIC_API_KEY=sk-ant-api03-...

# Email (Resend)
RESEND_API_KEY=re_...
ADMIN_EMAIL=admin@example.com

# App URL (used for CSRF validation in production)
NEXT_PUBLIC_APP_URL=https://your-domain.vercel.app

# Analytics (optional — leave empty to disable)
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_META_PIXEL_ID=

# AI Agents (optional — agents work without these, just won't notify via LINE)
AGENT_WEBHOOK_SECRET=your-webhook-secret
LINE_NOTIFY_TOKEN=your-line-notify-token
CRON_SECRET=your-vercel-cron-secret
